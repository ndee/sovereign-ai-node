{
  "name": "sovereign-ai-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "bin": {
    "sovereign-node": "./dist/sovereign-node.js",
    "sovereign-node-api": "./dist/sovereign-node-api.js",
    "sovereign-tool": "./dist/sovereign-tool.js"
  },
  "scripts": {
    "dev:cli": "tsx src/bin/sovereign-node.ts",
    "dev:api": "tsx src/bin/sovereign-node-api.ts",
    "dev:tool": "tsx src/bin/sovereign-tool.ts",
    "build": "tsup src/bin/sovereign-node.ts src/bin/sovereign-node-api.ts src/bin/sovereign-node-onboarding-api.ts src/bin/sovereign-tool.ts --format esm --dts --out-dir dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "execa": "^9.6.0",
    "fastify": "^5.6.1",
    "imapflow": "^1.2.12",
    "json5": "^2.2.3",
    "pino": "^9.9.0",
    "postal-mime": "^2.7.3",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^22.18.5",
    "pino-pretty": "^13.1.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
