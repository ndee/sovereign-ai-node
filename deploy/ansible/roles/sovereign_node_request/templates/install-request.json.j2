{
  "mode": "bundled_matrix",
  "connectivity": {
    "mode": {{ sovereign_node_connectivity_mode | to_json }}
  }{% if sovereign_node_connectivity_mode == 'relay' %},
  "relay": {
    "controlUrl": {{ sovereign_node_relay_control_url | to_json }}{% if sovereign_node_relay_enrollment_token | length > 0 %},
    "enrollmentToken": {{ sovereign_node_relay_enrollment_token | to_json }}{% endif %}
  }{% endif %},
  "openclaw": {
    "manageInstallation": {{ sovereign_openclaw_manage_installation | to_json }},
    "installMethod": {{ sovereign_openclaw_install_method | to_json }},
    "version": {{ sovereign_openclaw_version | string | to_json }},
    "skipIfCompatibleInstalled": {{ sovereign_openclaw_skip_if_compatible_installed | to_json }},
    "forceReinstall": {{ sovereign_openclaw_force_reinstall | to_json }},
    "runOnboard": {{ sovereign_openclaw_run_onboard | to_json }}
  },
  "openrouter": {
    "model": {{ sovereign_openrouter_model | to_json }},
    "secretRef": {{ sovereign_openrouter_secret_ref | to_json }}
  }{% if sovereign_imap_enabled %},
  "imap": {
    "host": {{ sovereign_imap_host | to_json }},
    "port": {{ sovereign_imap_port | int }},
    "tls": {{ sovereign_imap_tls | to_json }},
    "username": {{ sovereign_imap_username | to_json }},
    "secretRef": {{ sovereign_imap_secret_ref | to_json }},
    "mailbox": {{ sovereign_imap_mailbox | to_json }}
  }{% endif %},
  "matrix": {
    "homeserverDomain": {{ sovereign_matrix_homeserver_domain | to_json }},
    "publicBaseUrl": {{ sovereign_matrix_public_base_url | to_json }},
    "federationEnabled": {{ sovereign_matrix_federation_enabled | to_json }},
    "tlsMode": {{ sovereign_matrix_tls_mode | to_json }},
    "alertRoomName": {{ sovereign_matrix_alert_room_name | to_json }}
  },
  "operator": {
    "username": {{ sovereign_operator_username | to_json }}
  },
  "bots": {
    "selected": {{ sovereign_selected_bots | to_json }},
    "config": {
      "mail-sentinel": {
        "pollInterval": {{ sovereign_mail_sentinel_poll_interval | to_json }},
        "lookbackWindow": {{ sovereign_mail_sentinel_lookback_window | to_json }},
        "defaultReminderDelay": {{ sovereign_mail_sentinel_default_reminder_delay | to_json }},
        "digestInterval": {{ sovereign_mail_sentinel_digest_interval | to_json }},
        "e2eeAlertRoom": {{ sovereign_mail_sentinel_e2ee_alert_room | to_json }}
      }
    }
  },
  "advanced": {
    "rollbackPolicy": {{ sovereign_node_advanced_rollback_policy | to_json }},
    "skipPreflight": {{ sovereign_node_advanced_skip_preflight | to_json }},
    "nonInteractive": {{ sovereign_node_advanced_non_interactive | to_json }}
  }
}
