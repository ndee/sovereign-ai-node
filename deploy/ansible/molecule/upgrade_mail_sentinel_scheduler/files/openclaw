#!/usr/bin/env python3
import json
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
STATE_FILE = ROOT / "state" / "cron_jobs.json"


def load_jobs():
    return json.loads(STATE_FILE.read_text(encoding="utf-8"))


def save_jobs(jobs):
    STATE_FILE.write_text(json.dumps(jobs, indent=2) + "\n", encoding="utf-8")


def main():
    args = sys.argv[1:]
    if args == ["cron", "list", "--json"]:
        json.dump(load_jobs(), sys.stdout)
        sys.stdout.write("\n")
        return 0
    if len(args) == 3 and args[:2] == ["cron", "rm"]:
        job_id = args[2]
        jobs = load_jobs()
        save_jobs([job for job in jobs if job.get("id") != job_id])
        return 0
    sys.stderr.write(f"unsupported openclaw args: {args}\n")
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
