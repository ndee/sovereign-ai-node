#!/usr/bin/env python3
import json
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
STATE_FILE = ROOT / "state" / "timer_state.json"


def load_state():
    return json.loads(STATE_FILE.read_text(encoding="utf-8"))


def save_state(state):
    STATE_FILE.write_text(json.dumps(state, indent=2) + "\n", encoding="utf-8")


def main():
    args = sys.argv[1:]
    state = load_state()
    if len(args) == 3 and args[:2] == ["enable", "--now"]:
        state["enabled"] = True
        state["active"] = "active"
        save_state(state)
        return 0
    if len(args) == 2 and args[0] == "is-enabled":
        if state.get("enabled"):
            sys.stdout.write("enabled\n")
            return 0
        sys.stdout.write("disabled\n")
        return 1
    if len(args) == 2 and args[0] == "is-active":
        active = state.get("active", "inactive")
        sys.stdout.write(f"{active}\n")
        return 0 if active == "active" else 3
    sys.stderr.write(f"unsupported systemctl args: {args}\n")
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
